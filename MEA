<!DOCTYPE html>
<html>
<head>
    <title>For My Love ❤️</title>
    <style>
        body {
            background: black;
            color: lime;
            font-family: monospace;
            padding: 20px;
        }
    </style>
</head>
<body>
    <pre id="screen"></pre>

    <script>
        const lines = [
            "Initializing girlfriend.exe...",
            "Scanning heart...",
            "100% Compatible ❤️",
            "🎁 Surprise Gift Detected!",
            "You are the best thing that ever happened to me.",
            "I Love You ❤️"
        ];

        let i = 0;
        const screen = document.getElementById("screen");

        const interval = setInterval(() => {
            screen.textContent += lines[i] + "\n";
            i++;
            if (i >= lines.length) clearInterval(interval);
        }, 1200);
    </script>
</body>
</html>